# Viewpoint（app-html-maker）環境変数のサンプル
# このファイルを .env.local にコピーして値を設定してください。
# .env.local / .env は .gitignore 済み（Git・GitHub には含めない）。
# すべて任意です。BYOK（アプリ内「⚙ AI 設定」でキー入力）だけで使う場合は未設定で構いません。

# Claude を使う場合（https://console.anthropic.com/）
ANTHROPIC_API_KEY=

# Gemini を使う場合（https://aistudio.google.com/apikey）
GEMINI_API_KEY=

# 推奨: サーバー環境変数のキーを使う場合のアクセス合言葉。
# 設定すると全 AI 系 API がパスコード必須になり、第三者の無断利用を防げます。
APP_PASSCODE=
