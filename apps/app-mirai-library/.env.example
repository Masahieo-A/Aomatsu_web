# ============================================================
# Auth (NextAuth.js / Auth.js v5)
# ============================================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=             # openssl rand -base64 32 で生成

# Google OAuth (Google Cloud Console で取得)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 許可するメールアドレスのドメイン (@ より後の部分)
ALLOWED_EMAIL_DOMAIN=example-school.ed.jp

# ============================================================
# Supabase
# ============================================================
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=

# ============================================================
# プロンプトテンプレート ({{USER_PROMPT}} が生徒の入力に置き換わる)
# ============================================================
SYSTEM_PROMPT_TEMPLATE="Create a warm, photorealistic illustration of one floor of an ideal future library, viewed as a wide interior scene. The library is not only a place for borrowing books but also a community hub where people gather, learn, and create. Render the following student idea faithfully and beautifully:\n\n---\n{{USER_PROMPT}}\n---\n\nStyle: bright natural lighting, friendly atmosphere, detailed but not cluttered, suitable for a high school presentation slide. No text or letters in the image."

# ============================================================
# 利用回数上限 (デフォルト: 2)
# ============================================================
MAX_GENERATIONS_PER_USER=2
