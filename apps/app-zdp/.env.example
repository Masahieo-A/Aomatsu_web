# =============================================================
#  ZDP モノレポ 環境変数サンプル
#  各アプリの直下（apps/zdp/.env.local, apps/master-editor/.env.local）に
#  コピーして値を設定してください。
# =============================================================

# --- Gemini API（両アプリ共通・必須） -------------------------
# https://aistudio.google.com/app/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here
# 使用モデル（Flash系統のみ。要件: 上位モデル禁止）
GEMINI_MODEL=gemini-flash-latest

# --- Google Sheets（ZDPアプリのDB・任意） --------------------
# 未設定の場合はローカルJSON(.data/)にフォールバックして動作します。
# サービスアカウントのメールとキーを設定してください。
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxxx@yyyy.iam.gserviceaccount.com
# 改行を \n にエスケープした private_key を1行で
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- マスタアプリの認証（任意・簡易Basic認証） ---------------
MASTER_BASIC_USER=teacher
MASTER_BASIC_PASS=change_me

# --- マスタアプリのデータ保存先（任意） ----------------------
# 未設定なら apps/master-editor/.data/ に保存します。
# Google Drive同期(IO-03)を使う場合のみ設定。
MASTER_DATA_DIR=
