# Supabaseプロジェクトの Project Settings > API から取得（Project URL）
NEXT_PUBLIC_SUPABASE_URL=

# Supabaseプロジェクトの Project Settings > API から取得（anon / public key）
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabaseプロジェクトの Project Settings > API から取得（service_role key）。
# クライアントに絶対公開しないこと。npm run seed（scripts/seed.ts）でのみ使用する。
SUPABASE_SERVICE_ROLE_KEY=

# アプリの公開URL（本番: https://... / ローカル開発: http://localhost:3000）。
# OAuthのリダイレクト先などに使用する。
NEXT_PUBLIC_SITE_URL=

# 青松AIコーパスパイプライン（03_tag / 05_kernel_draft）用のLLM APIキー。
# 既定プロバイダは Gemini。aistudio.google.com で無料発行できる（詳細: pipeline/README.md）。
GEMINI_API_KEY=

# （任意）--provider claude で実行する場合のみ必要。console.anthropic.com で取得。
ANTHROPIC_API_KEY=
